[Unit]
Description=elemix playground
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
# Point this at wherever the repo (with docker-compose.yml) lives on the host.
WorkingDirectory=/home/lukasz/dev/playground
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
RemainAfterExit=yes
StandardOutput=syslog

[Install]
WantedBy=multi-user.target
